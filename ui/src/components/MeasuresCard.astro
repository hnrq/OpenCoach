---
import type { CollectionEntry } from "astro:content";
import Window from "./Window.astro";

interface Props {
	entry: CollectionEntry<"measures">;
}
const { entry } = Astro.props;
const { core_metrics, mandatory_sites, appointment_notes } = entry.data;

const siteLabels: Record<string, string> = {
	chest: "Chest",
	waist_narrowest: "Waist (narrowest)",
	umbilical: "Umbilical",
	hip_widest: "Hip (widest)",
	thigh_mid: "Thigh (mid)",
	bicep_flexed: "Bicep (flexed)",
	forearm: "Forearm",
};
---

<Window title={entry.id.replace('measures-', '')}>
  <fieldset class="tui-fieldset cyan-168-border mb-4 min-w-0">
    <legend class="cyan-168-text">Core Metrics</legend>
    <div class="overflow-x-auto">
      <table class="tui-table w-max min-w-full">
        <tbody>
          <tr><td>Weight</td><td class="right-align">{core_metrics.weight} kg</td></tr>
          <tr><td>Body Fat</td><td class="right-align">{core_metrics.body_fat_pct}%</td></tr>
        </tbody>
      </table>
    </div>
  </fieldset>

  {mandatory_sites && Object.keys(mandatory_sites).length > 0 && (
    <fieldset class="tui-fieldset yellow-168-border mb-4 min-w-0">
      <legend class="yellow-168-text">Measurements (cm)</legend>
      <div class="overflow-x-auto">
        <table class="tui-table w-max min-w-full">
          <tbody>
            {Object.entries(mandatory_sites).map(([key, val]) => (
              <tr>
                <td>{siteLabels[key] ?? key}</td>
                <td class="right-align">{val} cm</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </fieldset>
  )}

  {appointment_notes && (appointment_notes.goal || appointment_notes.coach_summary) && (
    <fieldset class="tui-fieldset white-168-border min-w-0">
      <legend class="white-168-text">Notes</legend>
      {appointment_notes.goal && <p class="m-0"><strong>Goal:</strong> {appointment_notes.goal}</p>}
      {appointment_notes.energy_levels && <p class="m-0 mt-2"><strong>Energy:</strong> {appointment_notes.energy_levels}</p>}
      {appointment_notes.sleep && <p class="m-0 mt-2"><strong>Sleep:</strong> {appointment_notes.sleep}</p>}
      {appointment_notes.coach_summary && <p class="m-0 mt-2"><strong>Coach:</strong> {appointment_notes.coach_summary}</p>}
    </fieldset>
  )}
</Window>
