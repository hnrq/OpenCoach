---
import type { CollectionEntry } from 'astro:content';
import Window from './Window.astro';

interface Props {
  entry: CollectionEntry<'diet'>;
}
const { entry } = Astro.props;
const { daily_targets, meal_structure, adjustments } = entry.data;
---

<Window title={entry.id.replace('diet-', '')}>

  <fieldset class="tui-fieldset cyan-168-border mb-4">
    <legend class="cyan-168-text">Daily Targets</legend>
    <table class="tui-table full-width">
      <tbody>
        <tr><td>Calories</td><td class="right-align">{daily_targets.calories} kcal</td></tr>
        <tr><td>Protein</td><td class="right-align">{daily_targets.protein_g} g</td></tr>
        <tr><td>Carbs</td><td class="right-align">{daily_targets.carbs_g} g</td></tr>
        <tr><td>Fats</td><td class="right-align">{daily_targets.fats_g} g</td></tr>
      </tbody>
    </table>
  </fieldset>

  {meal_structure && (
    <fieldset class="tui-fieldset yellow-168-border mb-4">
      <legend class="yellow-168-text">Meal Structure</legend>
      {meal_structure.pre_workout && <p class="m-0"><strong>Pre-workout:</strong> {meal_structure.pre_workout}</p>}
      {meal_structure.post_workout && <p class="m-0"><strong>Post-workout:</strong> {meal_structure.post_workout}</p>}
    </fieldset>
  )}

  {adjustments && (
    <fieldset class="tui-fieldset white-168-border">
      <legend class="white-168-text">Adjustments</legend>
      <p class="m-0">{adjustments}</p>
    </fieldset>
  )}

</Window>
