---
import type { CollectionEntry } from "astro:content";
import Window from "./Window.astro";

interface Props {
	entry: CollectionEntry<"training">;
}
const { entry } = Astro.props;
const { sessions, progression } = entry.data;
---

<Window title={entry.id.replace('training-', '')}>

  {sessions ? (sessions.map(s => {
    // Exercises from direct list or first alternating week found
    const altWeeks = s.alternating_weeks
      ? Object.values(s.alternating_weeks)
      : [];
    const exercises = s.exercises ?? altWeeks[0]?.exercises ?? [];
    return (
      <fieldset class="w-full min-w-0 tui-fieldset cyan-168-border mb-4">
        <legend class="cyan-168-text">{s.day}{s.focus ? ` — ${s.focus}` : ''}</legend>
        {s.scheduling_note && (
          <p class="m-0 mb-2 white-168-text">{s.scheduling_note}</p>
        )}
        {s.metabolic_primer && (
          <p class="m-0 mb-2 yellow-168-text">
            ⚡ {s.metabolic_primer.name}
            {s.metabolic_primer.format && ` (${s.metabolic_primer.format}`}
            {s.metabolic_primer.duration_min && `, ${s.metabolic_primer.duration_min} min`}
            {s.metabolic_primer.format && ')'}
            {s.metabolic_primer.protocol && <span class="white-168-text"> — {s.metabolic_primer.protocol}</span>}
          </p>
        )}

        {exercises.length > 0 && (
          <div class="overflow-x-auto">
            <table class="tui-table table-fixed sm:table-auto w-max min-w-full">
              <thead>
                <tr>
                  <th class="w-44 sm:w-auto">Exercise</th>
                  <th>Sets</th>
                  <th>Reps</th>
                  <th>RPE</th>
                </tr>
              </thead>
              <tbody>
                {exercises.map(ex => (
                  <tr>
                    <td>
                      {ex.name}
                      {ex.note && <span class="white-168-text !text-xs block">{ex.note}</span>}
                    </td>
                    <td class="center-align">{ex.sets ?? ex.working_sets ?? '—'}</td>
                    <td class="center-align">{ex.reps ?? '—'}</td>
                    <td class="center-align">{ex.rpe ?? '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {s.alternating_weeks && Object.keys(s.alternating_weeks).length > 1 && (
          <details class="mt-2">
            <summary class="white-168-text" style="cursor:pointer">Alternating weeks</summary>
            {Object.entries(s.alternating_weeks).map(([weekKey, week]) => week.exercises && (
              <div class="mt-2 ml-2">
                <strong class="cyan-168-text">{week.label ?? weekKey}</strong>
                <div class="overflow-x-auto">
                  <table class="tui-table w-max min-w-full mt-1">
                    <tbody>
                      {week.exercises.map(ex => (
                        <tr>
                          <td>{ex.name}</td>
                          <td class="center-align">{ex.sets ?? ex.working_sets ?? '—'}</td>
                          <td class="center-align">{ex.reps ?? '—'}</td>
                          <td class="center-align">{ex.rpe ?? '—'}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
          </details>
        )}
      </fieldset>
    );
  })) : (
    <p class="white-168-text m-0">No training data.</p>
  )}

  {progression && (
    <fieldset class="tui-fieldset white-168-border mt-4">
      <legend class="white-168-text">Progression</legend>
      <p class="m-0 white-168-text" style="font-size:0.9em">{
        typeof progression === "object" && "rule" in progression
          ? String(progression.rule)
          : JSON.stringify(progression)
      }</p>
    </fieldset>
  )}

</Window>
