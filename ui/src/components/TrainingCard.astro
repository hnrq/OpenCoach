---
import type { CollectionEntry } from 'astro:content';
import Window from './Window.astro';

interface Props {
  entry: CollectionEntry<'training'>;
}
const { entry } = Astro.props;
const { sessions, circuits, progression_rule, progression_logic } = entry.data;
---

<Window title={entry.id.replace('training-', '')}>

  {sessions ? (
    <>
      {sessions.map(s => {
        const exercises = s.exercises ?? s.alternating_weeks?.push_week?.exercises ?? [];
        return (
          <fieldset class="tui-fieldset cyan-168-border mb-4">
            <legend class="cyan-168-text">{s.day} — {s.focus ?? s.id}</legend>

            {s.metabolic_primer && (
              <p class="m-0 mb-2 yellow-168-text">
                ⚡ Primer: {s.metabolic_primer.name} ({s.metabolic_primer.format}{s.metabolic_primer.duration_min ? `, ${s.metabolic_primer.duration_min} min` : ''})
              </p>
            )}

            {exercises.length > 0 && (
              <table class="tui-table full-width">
                <thead>
                  <tr>
                    <th>Exercise</th>
                    <th class="center-align">Sets</th>
                    <th class="center-align">Reps</th>
                    <th class="center-align">RPE</th>
                  </tr>
                </thead>
                <tbody>
                  {exercises.map(ex => (
                    <tr>
                      <td>{ex.name}</td>
                      <td class="center-align">{ex.working_sets ?? '—'}</td>
                      <td class="center-align">{ex.reps ?? '—'}</td>
                      <td class="center-align">{ex.rpe ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}

            {s.alternating_weeks && (
              <p class="m-0 mt-2 white-168-text">Alternates push/pull weekly — see full plan for both variants.</p>
            )}
          </fieldset>
        );
      })}

      {(progression_rule ?? progression_logic) && (
        <fieldset class="tui-fieldset yellow-168-border">
          <legend class="yellow-168-text">Progression</legend>
          <p class="m-0">{progression_rule ?? progression_logic}</p>
        </fieldset>
      )}
    </>
  ) : circuits ? (
    <>
      {circuits.map(circuit => (
        <fieldset class="tui-fieldset cyan-168-border mb-4">
          <legend class="cyan-168-text">{circuit.name}</legend>
          <table class="tui-table full-width">
            <thead>
              <tr>
                <th>Exercise</th>
                <th class="center-align">Sets</th>
                <th class="center-align">Reps</th>
                <th class="center-align">RPE</th>
              </tr>
            </thead>
            <tbody>
              {circuit.exercises.map(ex => (
                <tr>
                  <td>{ex.name}</td>
                  <td class="center-align">{ex.sets}</td>
                  <td class="center-align">{ex.reps}</td>
                  <td class="center-align">{ex.rpe ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </fieldset>
      ))}

      {progression_logic && (
        <fieldset class="tui-fieldset yellow-168-border">
          <legend class="yellow-168-text">Progression</legend>
          <p class="m-0">{progression_logic}</p>
        </fieldset>
      )}
    </>
  ) : (
    <p class="white-168-text m-0">No training data.</p>
  )}

</Window>
