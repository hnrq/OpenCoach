---
import Layout from '../layouts/Layout.astro';
import Window from '../components/Window.astro';
import { getCollection } from 'astro:content';

const measures = (await getCollection('measures')).sort((a, b) => b.id.localeCompare(a.id));
const diet     = (await getCollection('diet')).sort((a, b) => b.id.localeCompare(a.id));
const training = (await getCollection('training')).sort((a, b) => b.id.localeCompare(a.id));

const latest         = measures[0];
const latestDiet     = diet[0];
const latestTraining = training[0];

const goal    = latest?.data.appointment_notes?.goal;
const summary = latest?.data.appointment_notes?.coach_summary;

const base = import.meta.env.BASE_URL;
---

<Layout title="OpenCoach" activePage="home">

  <div class="flex flex-col gap-2 pb-10">
  {goal && (
    <fieldset class="tui-fieldset cyan-168-border mb-4">
      <legend class="cyan-168-text">Goal</legend>
      <p class="cyan-168-text m-0">{goal}</p>
    </fieldset>
  )}

  {summary && (
    <fieldset class="tui-fieldset white-168-border mb-4">
      <legend class="white-168-text">Coach Notes</legend>
      <p class="white-168-text m-0">{summary}</p>
    </fieldset>
    )}
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

    {latest && (
      <Window title="Latest Measures">
        <div class="flex flex-col gap-4">
          <span class="flex flex-col">
            <span><span class="cyan-168-text">Weight:</span> {latest.data.core_metrics.weight} kg</span>
            <span><span class="cyan-168-text">Body Fat:</span> {latest.data.core_metrics.body_fat_pct}%</span>
          </span>
          <a href={`${base}measures/${latest.id}`} class="tui-button m-0">View →</a>
        </div>
      </Window>
    )}

    {latestDiet && (
      <Window title="Latest Diet">
        <div class="flex flex-col gap-4">
          <span class="flex flex-col">
            <span><span class="cyan-168-text">Calories:</span> {latestDiet.data.daily_targets.calories} kcal</span>
            <span><span class="cyan-168-text">Protein:</span> {latestDiet.data.daily_targets.protein_g}g</span>
          </span>
          <a href={`${base}diet/${latestDiet.id}`} class="tui-button m-0">View →</a>
        </div>
      </Window>
    )}

    {latestTraining && (
      <Window title="Latest Training">
        <div class="flex flex-col gap-4">
          <span class="flex flex-col">
            <span><span class="cyan-168-text">Circuits:</span> {latestTraining.data.circuits.length}</span>
            <span><span class="cyan-168-text">Exercises:</span> {latestTraining.data.circuits.reduce((n, c) => n + c.exercises.length, 0)}</span>
          </span>
          <a href={`${base}training/${latestTraining.id}`} class="tui-button m-0">View →</a>
        </div>
      </Window>
    )}

  </div>

</Layout>
