---
import { getCollection } from "astro:content";
import BodyCompositionChart from "../components/BodyCompositionChart.astro";
import PreviewCard from "../components/PreviewCard.astro";
import Window from "../components/Window.astro";
import Layout from "../layouts/Layout.astro";

const measures = (await getCollection("measures")).sort((a, b) =>
	b.id.localeCompare(a.id),
);
const diet = (await getCollection("diet")).sort((a, b) =>
	b.id.localeCompare(a.id),
);
const training = (await getCollection("training")).sort((a, b) =>
	b.id.localeCompare(a.id),
);
const appointments = (await getCollection("appointments")).sort((a, b) =>
	b.id.localeCompare(a.id),
);

const latest = measures[0];
const latestDiet = diet[0];
const latestTraining = training[0];
const latestAppointment = appointments[0];

const goal = latest?.data.appointment_notes?.goal;
const summary = latest?.data.appointment_notes?.coach_summary;
---

<Layout title="OpenCoach" activePage="home">

  <div class="flex flex-col gap-2 pb-10 w-full">
  {goal && (
    <fieldset class="tui-fieldset cyan-168-border mb-4">
      <legend class="cyan-168-text">Goal</legend>
      <p class="cyan-168-text m-0">{goal}</p>
    </fieldset>
  )}

  {summary && (
    <fieldset class="tui-fieldset white-168-border mb-4">
      <legend class="white-168-text">Coach Notes</legend>
      <p class="white-168-text m-0">{summary}</p>
    </fieldset>
    )}

  {measures.length > 1 && <BodyCompositionChart measures={measures} />}
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

    {latest && <PreviewCard entry={latest} href={`/measures/${latest.id}`} title="Latest Measures" />}
    {latestDiet && <PreviewCard entry={latestDiet} href={`/diet/${latestDiet.id}`} title="Latest Diet" />}
    {latestTraining && <PreviewCard entry={latestTraining} href={`/training/${latestTraining.id}`} title="Latest Training" />}
    {latestAppointment && <PreviewCard entry={latestAppointment} href={`/appointments/${latestAppointment.id}`} title="Latest Appointment" />}

  </div>

</Layout>
div>

</Layout>
