---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Window from "../../components/Window.astro";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const [diet, training, measures, appointments] = await Promise.all([
		getCollection("diet"),
		getCollection("training"),
		getCollection("measures"),
		getCollection("appointments"),
	]);
	const sort = <T extends { id: string }>(arr: T[]) =>
		[...arr].sort((a, b) => b.id.localeCompare(a.id));

	return [
		{
			params: { section: "diet" },
			props: { entries: sort(diet), type: "diet" as const },
		},
		{
			params: { section: "training" },
			props: { entries: sort(training), type: "training" as const },
		},
		{
			params: { section: "measures" },
			props: { entries: sort(measures), type: "measures" as const },
		},
		{
			params: { section: "appointments" },
			props: { entries: sort(appointments), type: "appointments" as const },
		},
	];
}

type Props =
	| { entries: CollectionEntry<"diet">[]; type: "diet" }
	| { entries: CollectionEntry<"training">[]; type: "training" }
	| { entries: CollectionEntry<"measures">[]; type: "measures" }
	| { entries: CollectionEntry<"appointments">[]; type: "appointments" };

const { entries, type } = Astro.props;
const { section } = Astro.params;
const base = import.meta.env.BASE_URL;
const sectionLabel = section.charAt(0).toUpperCase() + section.slice(1);

function formatDate(id: string) {
	return id.replace(/^[a-z]+-/, "");
}

const dietEntries =
	type === "diet" ? (entries as CollectionEntry<"diet">[]) : [];
const trainingEntries =
	type === "training" ? (entries as CollectionEntry<"training">[]) : [];
const measuresEntries =
	type === "measures" ? (entries as CollectionEntry<"measures">[]) : [];
const appointmentEntries =
	type === "appointments" ? (entries as CollectionEntry<"appointments">[]) : [];
---

<Layout title={`${sectionLabel} — OpenCoach`} activePage={type}>

  <h1 class="white-168-text mb-4">{sectionLabel}</h1>

  <section class="grid grid-cols-1 auto-rows-auto sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
  {entries.length === 0 && (
    <p class="yellow-168-text">No {section} data found.</p>
  )}

  {type === 'diet' && dietEntries.map(entry => {
    const targets = entry.data.day_types?.gym_day?.total_targets ?? entry.data.daily_targets;
    return (
      <Window title={formatDate(entry.id)}>
        <div class="flex flex-col gap-2">
          <span class="flex flex-col">
            {targets ? (
              <>
                <span><span class="cyan-168-text">Calories:</span> {targets.calories} kcal</span>
                <span><span class="cyan-168-text">Protein:</span> {targets.protein_g}g</span>
                <span><span class="cyan-168-text">Carbs:</span> {targets.carbs_g}g</span>
                <span><span class="cyan-168-text">Fats:</span> {targets.fats_g}g</span>
              </>
            ) : (
              <span class="white-168-text">Day-type plan</span>
            )}
          </span>
          <a href={`${base}/${section}/${entry.id}`} class="tui-button m-0">View →</a>
        </div>
      </Window>
    );
  })}

  {type === 'training' && trainingEntries.map(entry => {
    const sessionCount = entry.data.sessions?.length ?? entry.data.circuits?.length ?? 0;
    const exerciseCount = entry.data.sessions
      ? entry.data.sessions.reduce((n, s) => n + (s.exercises?.length ?? 0), 0)
      : entry.data.circuits?.reduce((n, c) => n + c.exercises.length, 0) ?? 0;
    return (
      <Window title={formatDate(entry.id)}>
        <div class="flex flex-col gap-2">
          <span class="flex flex-col">
            <span><span class="cyan-168-text">{entry.data.sessions ? 'Sessions' : 'Circuits'}:</span> {sessionCount}</span>
            <span><span class="cyan-168-text">Exercises:</span> {exerciseCount}</span>
          </span>
          <a href={`${base}/${section}/${entry.id}`} class="tui-button m-0">View →</a>
        </div>
      </Window>
    );
  })}

  {type === 'measures' && measuresEntries.map(entry => (
    <Window title={formatDate(entry.id)}>
      <div class="flex flex-col gap-2">
        <span class="flex flex-col">
          <span><span class="cyan-168-text">Weight:</span> {entry.data.core_metrics.weight} kg</span>
          <span><span class="cyan-168-text">BF%:</span> {entry.data.core_metrics.body_fat_pct}%</span>
        </span>
        <a href={`${base}/${section}/${entry.id}`} class="tui-button m-0">View →</a>
      </div>
    </Window>
  ))}

  {type === 'appointments' && appointmentEntries.map(entry => (
    <Window title={formatDate(entry.id)}>
      <div class="flex flex-col gap-2">
        <span class="flex flex-col">
          <span><span class="cyan-168-text">Decisions:</span> {entry.data.decisions.length}</span>
          {entry.data.plan_rationale_deltas.length > 0 && (
            <span><span class="cyan-168-text">Rationale:</span> {entry.data.plan_rationale_deltas.length} items</span>
          )}
          {entry.data.notes && (
            <span class="white-168-text" style="font-size:0.85em;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{entry.data.notes}</span>
          )}
        </span>
        <a href={`${base}/${section}/${entry.id}`} class="tui-button m-0">View →</a>
      </div>
    </Window>
  ))}
    </section>

</Layout>
