---
import Layout from '../../layouts/Layout.astro';
import DietCard from '../../components/DietCard.astro';
import TrainingCard from '../../components/TrainingCard.astro';
import MeasuresCard from '../../components/MeasuresCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const [diet, training, measures] = await Promise.all([
    getCollection('diet'),
    getCollection('training'),
    getCollection('measures'),
  ]);

  return [
    ...diet.map(entry => ({
      params: { section: 'diet', item: entry.id },
      props: { entry, type: 'diet' as const },
    })),
    ...training.map(entry => ({
      params: { section: 'training', item: entry.id },
      props: { entry, type: 'training' as const },
    })),
    ...measures.map(entry => ({
      params: { section: 'measures', item: entry.id },
      props: { entry, type: 'measures' as const },
    })),
  ];
}

type Props =
  | { entry: Awaited<ReturnType<typeof getCollection<'diet'>>>[number];     type: 'diet' }
  | { entry: Awaited<ReturnType<typeof getCollection<'training'>>>[number]; type: 'training' }
  | { entry: Awaited<ReturnType<typeof getCollection<'measures'>>>[number]; type: 'measures' };

const { entry, type } = Astro.props;
const { section } = Astro.params;
const base = import.meta.env.BASE_URL;

const sectionLabel = section.charAt(0).toUpperCase() + section.slice(1);
---

<Layout
  title={`${entry.id} — OpenCoach`}
  activePage={type}
>

  <div style="margin-bottom: 1rem;">
    <a href={`${base}${section}`} class="cyan-168-text">← Back to {sectionLabel}</a>
  </div>

  {type === 'diet'     && <DietCard     entry={entry as Awaited<ReturnType<typeof getCollection<'diet'>>>[number]} />}
  {type === 'training' && <TrainingCard entry={entry as Awaited<ReturnType<typeof getCollection<'training'>>>[number]} />}
  {type === 'measures' && <MeasuresCard entry={entry as Awaited<ReturnType<typeof getCollection<'measures'>>>[number]} />}

</Layout>
