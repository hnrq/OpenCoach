{
  "name": "@nextsystems/oac",
  "version": "0.7.1",
  "description": "AI agent framework for plan-first development workflows with approval-based execution. Multi-language support for TypeScript, Python, Go, Rust and more.",
  "bin": {
    "oac": "./bin/oac.js"
  },
  "files": [
    ".opencode/agent/",
    ".opencode/command/",
    ".opencode/context/",
    ".opencode/plugin/",
    ".opencode/profiles/",
    ".opencode/prompts/",
    ".opencode/scripts/",
    ".opencode/skills/",
    ".opencode/tool/",
    ".opencode/config.json",
    ".opencode/opencode.json",
    "!.opencode/tool/node_modules/",
    "!.opencode/node_modules/",
    "!**/node_modules/",
    "scripts/",
    "bin/",
    "registry.json",
    "install.sh",
    "VERSION",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTEXT_SYSTEM_GUIDE.md",
    "packages/cli/dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "pnpm test:all",
    "test:all": "cd evals/framework && pnpm eval:sdk",
    "test:core": "pnpm test:openagent:core",
    "test:openagent": "cd evals/framework && pnpm eval:sdk -- --agent=openagent",
    "test:openagent:core": "cd evals/framework && pnpm eval:sdk:core -- --agent=openagent",
    "test:opencoder": "cd evals/framework && pnpm eval:sdk -- --agent=opencoder",
    "test:openagent:grok": "pnpm test:openagent -- --model=opencode/grok-code-fast",
    "test:openagent:claude": "pnpm test:openagent -- --model=anthropic/claude-3-5-sonnet-20241022",
    "test:openagent:gpt4": "pnpm test:openagent -- --model=openai/gpt-4-turbo",
    "test:opencoder:grok": "pnpm test:opencoder -- --model=opencode/grok-code-fast",
    "test:opencoder:claude": "pnpm test:opencoder -- --model=anthropic/claude-3-5-sonnet-20241022",
    "test:opencoder:gpt4": "pnpm test:opencoder -- --model=openai/gpt-4-turbo",
    "test:all:grok": "pnpm test:all -- --model=opencode/grok-code-fast",
    "test:all:claude": "pnpm test:all -- --model=anthropic/claude-3-5-sonnet-20241022",
    "test:all:gpt4": "pnpm test:all -- --model=openai/gpt-4-turbo",
    "test:pattern": "cd evals/framework && pnpm eval:sdk -- --pattern",
    "test:debug": "cd evals/framework && pnpm eval:sdk -- --debug",
    "test:openagent:developer": "pnpm test:openagent -- --pattern='developer/*.yaml'",
    "test:openagent:context": "pnpm test:openagent -- --pattern='context-loading/*.yaml'",
    "test:openagent:business": "pnpm test:openagent -- --pattern='business/*.yaml'",
    "test:opencoder:developer": "pnpm test:opencoder -- --pattern='developer/*.yaml'",
    "test:opencoder:bash": "pnpm test:opencoder -- --pattern='developer/bash-*.yaml'",
    "test:ci": "pnpm test:ci:openagent && pnpm test:ci:opencoder",
    "test:ci:openagent": "pnpm test:openagent -- --pattern='smoke-test.yaml' --no-evaluators",
    "test:ci:opencoder": "pnpm test:opencoder -- --pattern='developer/simple-bash-test.yaml' --no-evaluators",
    "dashboard": "cd evals/results && ./serve.sh",
    "dashboard:open": "pnpm dashboard && open http://localhost:8000",
    "results:openagent": "echo 'OpenAgent results:' && ls -lh evals/results/history/*openagent*.json 2>/dev/null | tail -5 || echo 'No results yet'",
    "results:opencoder": "echo 'OpenCoder results:' && ls -lh evals/results/history/*opencoder*.json 2>/dev/null | tail -5 || echo 'No results yet'",
    "results:latest": "cat evals/results/latest.json 2>/dev/null | jq '.agent, .passed, .failed' || echo 'No results yet'",
    "version": "node -p \"require('./package.json').version\"",
    "version:bump": "./scripts/versioning/bump-version.sh",
    "version:bump:patch": "pnpm version patch --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "version:bump:minor": "pnpm version minor --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "version:bump:major": "pnpm version major --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "version:bump:alpha": "pnpm version prerelease --preid=alpha --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "version:bump:beta": "pnpm version prerelease --preid=beta --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "version:bump:rc": "pnpm version prerelease --preid=rc --no-git-tag-version && node -p \"require('./package.json').version\" > VERSION",
    "dev:setup": "cd evals/framework && pnpm install",
    "dev:build": "cd evals/framework && pnpm build",
    "dev:test": "cd evals/framework && pnpm test",
    "dev:clean": "cd evals/framework && rm -rf dist node_modules && pnpm install",
    "validate:registry": "bun run scripts/registry/validate-registry.ts",
    "validate:context-links": "bun run scripts/validation/validate-markdown-links.ts",
    "validate:registry:verbose": "bun run scripts/registry/validate-registry.ts -v",
    "validate:registry:fix": "bun run scripts/registry/validate-registry.ts -f",
    "opencoach": "./.opencode/skills/opencoach/router.sh",
    "prune": "rm -rf diet training measures appointments analytics profile.json .opencode/context/coaching/athlete-notes.md"
  },
  "keywords": [
    "opencode",
    "openagents",
    "ai-agents",
    "code-generation",
    "development-workflow",
    "plan-first",
    "context-aware",
    "typescript",
    "python",
    "go",
    "rust",
    "cli",
    "automation"
  ],
  "author": "Darren Hinde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darrenhinde/OpenAgentsControl.git"
  },
  "bugs": {
    "url": "https://github.com/darrenhinde/OpenAgentsControl/issues"
  },
  "homepage": "https://github.com/darrenhinde/OpenAgentsControl#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "glob": "^13.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "pdf2json": "^4.0.2"
  }
}
